<div class="space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between">
    <div>
      <%= link_to "← History", workout_sessions_path, class: "text-sm text-zinc-500 hover:text-zinc-300 transition-colors" %>
      <h1 class="text-2xl font-bold text-zinc-100 mt-2">
        <%= @workout_session.routine&.name || "Freeform workout" %>
      </h1>
      <p class="text-zinc-500 text-xs mt-1"><%= @workout_session.created_at.strftime("%B %d, %Y · %H:%M") %></p>
    </div>

    <% unless @workout_session.completed? %>
      <%= button_to "Complete", complete_workout_session_path(@workout_session), method: :patch,
          data: { turbo_confirm: "Mark this workout as complete?" },
          class: "bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold text-sm px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
    <% else %>
      <span class="text-xs font-medium bg-emerald-900/40 text-emerald-400 border border-emerald-700 px-3 py-1.5 rounded-full">
        Completed
      </span>
    <% end %>
  </div>

  <%# Progress bar (only for routine-based sessions) %>
  <% if @exercises_with_sets.any? %>
    <% total_target = @exercises_with_sets.sum { |re| re.target_sets || 0 } %>
    <% total_logged = @workout_session.workout_sets.count %>
    <%= render "workout_sessions/progress", total: total_target, logged: total_logged %>
  <% end %>

  <%# Routine-based: one card per exercise %>
  <% if @exercises_with_sets.any? %>
    <% @exercises_with_sets.each do |re| %>
      <% exercise = re.exercise %>
      <% logged_sets = (@sets_by_exercise[exercise.id] || []).sort_by(&:set_number) %>

      <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
        <%# Exercise header with set counter %>
        <div class="px-4 py-3 border-b border-zinc-800 flex items-center justify-between">
          <div>
            <h2 class="font-semibold text-zinc-100 text-sm"><%= exercise.name %></h2>
            <p class="text-xs text-zinc-500">
              Target: <%= re.target_sets || "?" %> sets × <%= re.target_reps || "?" %> reps
            </p>
          </div>
          <span id="set_counter_<%= exercise.id %>" class="text-xs text-zinc-500">
            <%= logged_sets.count %> / <%= re.target_sets || "?" %> sets
          </span>
        </div>

        <%# Logged sets list — stream appends here %>
        <ul id="exercise_sets_<%= exercise.id %>" class="divide-y divide-zinc-800/50">
          <% logged_sets.each do |set| %>
            <%= render "workout_sets/workout_set", workout_set: set %>
          <% end %>
        </ul>

        <%# Log a set — stream replaces this form %>
        <% unless @workout_session.completed? %>
          <div class="px-4 py-3 border-t border-zinc-800/50 bg-zinc-950/30">
            <%= render "workout_sets/log_form",
                workout_session: @workout_session,
                exercise: exercise,
                next_set_number: logged_sets.count + 1,
                target_reps: re.target_reps,
                autofocus: false %>
          </div>
        <% end %>
      </div>
    <% end %>

  <% else %>
    <%# Freeform session %>
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-5">
      <h2 class="text-sm font-semibold text-zinc-300 mb-4">Log a set</h2>
      <%= form_with url: workout_session_workout_sets_path(@workout_session), class: "space-y-3" do |form| %>
        <div>
          <%= form.label :exercise_id, "Exercise", class: "block text-xs font-medium text-zinc-400 mb-1" %>
          <%= form.select :exercise_id,
              Exercise.ordered.map { |e| [e.name, e.id] },
              { prompt: "Select exercise" },
              class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
        </div>

        <div class="grid grid-cols-3 gap-2">
          <div>
            <%= form.label :set_number, "Set #", class: "block text-xs text-zinc-400 mb-1" %>
            <%= form.number_field :set_number, value: 1, min: 1,
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
          </div>
          <div>
            <%= form.label :reps, "Reps", class: "block text-xs text-zinc-400 mb-1" %>
            <%= form.number_field :reps, min: 1,
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
          </div>
          <div>
            <%= form.label :weight, "Weight", class: "block text-xs text-zinc-400 mb-1" %>
            <%= form.number_field :weight, step: 0.5, min: 0,
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <%= form.select :unit,
              WorkoutSet.units.keys.map { |u| [u, u] },
              { selected: "bodyweight" },
              class: "bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
          <%= form.hidden_field :completed, value: true %>
          <%= form.submit "Log set", class: "flex-1 bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold py-2 rounded-lg transition-colors cursor-pointer text-sm" %>
        </div>
      <% end %>
    </div>

    <% if @workout_session.workout_sets.any? %>
      <% @workout_session.workout_sets.includes(:exercise).group_by(&:exercise).each do |exercise, sets| %>
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
          <div class="px-4 py-3 border-b border-zinc-800">
            <h2 class="font-semibold text-zinc-100 text-sm"><%= exercise.name %></h2>
          </div>
          <ul class="divide-y divide-zinc-800/50">
            <% sets.sort_by(&:set_number).each do |set| %>
              <%= render "workout_sets/workout_set", workout_set: set %>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
