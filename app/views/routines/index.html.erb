<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-zinc-100">Routines</h1>
    <%= link_to "New routine", new_routine_path, class: "bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold text-sm px-4 py-2 rounded-lg transition-colors" %>
  </div>

  <% if @routines.empty? %>
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8 text-center">
      <p class="text-zinc-500 text-sm">No routines yet.</p>
      <%= link_to "Create your first routine", new_routine_path, class: "text-emerald-400 hover:text-emerald-300 text-sm font-medium transition-colors" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @routines.each do |routine| %>
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl px-5 py-4 flex items-center justify-between">
          <div>
            <h2 class="font-semibold text-zinc-100"><%= routine.name %></h2>
            <p class="text-xs text-zinc-500 mt-0.5"><%= routine.exercises.count %> exercises</p>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <%= link_to "View", routine_path(routine), class: "text-emerald-400 hover:text-emerald-300 font-medium transition-colors" %>
            <%= link_to "Edit", edit_routine_path(routine), class: "text-zinc-500 hover:text-zinc-300 transition-colors" %>
            <%= button_to "Delete", routine_path(routine), method: :delete,
                data: { turbo_confirm: "Delete this routine?" },
                class: "text-red-500 hover:text-red-400 transition-colors bg-transparent border-0 p-0 text-sm cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
