<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-zinc-100">Exercises</h1>
    <%= link_to "Add exercise", new_exercise_path,
        class: "text-sm bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold px-3 py-1.5 rounded-lg transition-colors" %>
  </div>

  <% @exercises_by_group.each do |group, exercises| %>
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
      <div class="px-4 py-3 border-b border-zinc-800">
        <h2 class="text-sm font-semibold text-emerald-400 uppercase tracking-wider"><%= group.humanize %></h2>
      </div>
      <ul class="divide-y divide-zinc-800">
        <% exercises.each do |exercise| %>
          <li class="px-4 py-3 flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-zinc-100"><%= exercise.name %></p>
              <% if exercise.description.present? %>
                <p class="text-xs text-zinc-500 mt-0.5 line-clamp-1"><%= exercise.description %></p>
              <% end %>
            </div>
            <div class="flex items-center gap-3">
              <%= link_to "View", exercise_path(exercise), class: "text-xs text-zinc-500 hover:text-zinc-300 transition-colors" %>
              <% if exercise.user_id == Current.user.id %>
                <%= link_to "Edit", edit_exercise_path(exercise), class: "text-xs text-zinc-500 hover:text-zinc-300 transition-colors" %>
                <%= button_to "Delete", exercise_path(exercise), method: :delete,
                    data: { turbo_confirm: "Delete #{exercise.name}?" },
                    class: "text-xs text-red-500 hover:text-red-400 transition-colors bg-transparent border-0 p-0 cursor-pointer" %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
