<div class="space-y-6">
  <div class="flex items-start justify-between">
    <div>
      <%= link_to "← Routines", routines_path, class: "text-sm text-zinc-500 hover:text-zinc-300 transition-colors" %>
      <h1 class="text-2xl font-bold text-zinc-100 mt-2"><%= @routine.name %></h1>
      <% if @routine.description.present? %>
        <p class="text-zinc-500 text-sm mt-1"><%= @routine.description %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3 text-sm shrink-0">
      <%= link_to "Edit", edit_routine_path(@routine), class: "text-zinc-500 hover:text-zinc-300 transition-colors" %>
      <%= link_to "Start workout", new_workout_session_path(routine_id: @routine.id),
          class: "bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold px-4 py-2 rounded-lg transition-colors" %>
    </div>
  </div>

  <%# Turbo Frame wraps both the list and add form so updates happen without a full reload %>
  <%= turbo_frame_tag "routine_exercises" do %>
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
      <div class="px-4 py-3 border-b border-zinc-800 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-zinc-300">Exercises</h2>
        <span class="text-xs text-zinc-500"><%= @routine.routine_exercises.count %> total</span>
      </div>

      <% if @routine.routine_exercises.empty? %>
        <p class="text-zinc-500 text-sm text-center py-8">No exercises yet. Add one below.</p>
      <% else %>
        <ul class="divide-y divide-zinc-800">
          <% @routine.routine_exercises.includes(:exercise).each do |re| %>
            <%= render "routine_exercises/routine_exercise", routine_exercise: re, routine: @routine %>
          <% end %>
        </ul>
      <% end %>
    </div>

    <%# Add exercise form — inside the same Turbo Frame %>
    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-5">
      <h2 class="text-sm font-semibold text-zinc-300 mb-4">Add exercise</h2>
      <%= form_with model: [@routine, @routine_exercise], class: "space-y-3" do |form| %>
        <div>
          <%= form.label :exercise_id, "Exercise", class: "block text-xs font-medium text-zinc-400 mb-1" %>
          <%= form.select :exercise_id,
              @exercises.map { |e| [e.name, e.id] },
              { prompt: "Select an exercise" },
              class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= form.label :target_sets, "Sets", class: "block text-xs font-medium text-zinc-400 mb-1" %>
            <%= form.number_field :target_sets, placeholder: "3", min: 1,
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
          </div>
          <div>
            <%= form.label :target_reps, "Reps", class: "block text-xs font-medium text-zinc-400 mb-1" %>
            <%= form.text_field :target_reps, placeholder: "10 or 8-12",
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
          </div>
        </div>

        <div>
          <%= form.label :notes, "Notes (optional)", class: "block text-xs font-medium text-zinc-400 mb-1" %>
          <%= form.text_field :notes, placeholder: "e.g. slow descent",
              class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
        </div>

        <%= form.submit "Add exercise", class: "w-full bg-zinc-700 hover:bg-zinc-600 text-zinc-100 font-medium py-2.5 rounded-lg transition-colors cursor-pointer text-sm" %>
      <% end %>
    </div>
  <% end %>
</div>
