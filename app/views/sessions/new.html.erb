<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-emerald-400 tracking-tight">Workout Register</h1>
      <p class="text-zinc-500 mt-1 text-sm">Track your calisthenics progress</p>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
      <h2 class="text-xl font-semibold text-zinc-100 mb-6">Sign in</h2>

      <%= form_with url: session_url do |form| %>
        <div class="space-y-4">
          <div>
            <%= form.label :email_address, "Email", class: "block text-sm font-medium text-zinc-400 mb-1" %>
            <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
                placeholder: "you@example.com", value: params[:email_address],
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm" %>
          </div>

          <div>
            <%= form.label :password, "Password", class: "block text-sm font-medium text-zinc-400 mb-1" %>
            <%= form.password_field :password, required: true, autocomplete: "current-password",
                placeholder: "••••••••", maxlength: 72,
                class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm" %>
          </div>
        </div>

        <div class="mt-6">
          <%= form.submit "Sign in", class: "w-full bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold py-2.5 rounded-lg transition-colors cursor-pointer text-sm" %>
        </div>
      <% end %>

      <div class="mt-4 flex items-center justify-between text-sm">
        <%= link_to "Forgot password?", new_password_path, class: "text-zinc-500 hover:text-zinc-300 transition-colors" %>
        <%= link_to "Create account", new_registration_path, class: "text-emerald-400 hover:text-emerald-300 transition-colors font-medium" %>
      </div>
    </div>
  </div>
</div>
