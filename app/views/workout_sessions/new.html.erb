<div class="space-y-4">
  <%= link_to "← History", workout_sessions_path, class: "text-sm text-zinc-500 hover:text-zinc-300 transition-colors" %>

  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <h1 class="text-xl font-bold text-zinc-100 mb-6">Start a workout</h1>

    <%= form_with model: WorkoutSession.new, url: workout_sessions_path, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :routine_id, "Routine (optional)", class: "block text-sm font-medium text-zinc-400 mb-1" %>
        <%= form.select :routine_id,
            @routines.map { |r| [r.name, r.id] },
            { prompt: "Freeform — no routine" },
            class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" %>
        <% if params[:routine_id].present? %>
          <% routine = @routines.find { |r| r.id == params[:routine_id].to_i } %>
          <script>document.querySelector('select[name="workout_session[routine_id]"]').value = "<%= params[:routine_id] %>";</script>
        <% end %>
      </div>

      <div>
        <%= form.label :notes, "Notes (optional)", class: "block text-sm font-medium text-zinc-400 mb-1" %>
        <%= form.text_area :notes, rows: 2, placeholder: "How are you feeling today?",
            class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2.5 text-zinc-100 placeholder-zinc-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm resize-none" %>
      </div>

      <%= form.submit "Start workout", class: "w-full bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold py-2.5 rounded-lg transition-colors cursor-pointer text-sm" %>
    <% end %>
  </div>
</div>
