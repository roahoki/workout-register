<div class="space-y-4">
  <%= link_to "← Exercises", exercises_path, class: "text-sm text-zinc-500 hover:text-zinc-300 transition-colors" %>

  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
    <div class="flex items-start justify-between mb-3">
      <h1 class="text-2xl font-bold text-zinc-100"><%= @exercise.name %></h1>
      <span class="text-xs font-medium bg-zinc-800 text-emerald-400 px-2.5 py-1 rounded-full">
        <%= @exercise.muscle_group.humanize %>
      </span>
    </div>
    <% if @exercise.description.present? %>
      <p class="text-zinc-400 text-sm leading-relaxed"><%= @exercise.description %></p>
    <% end %>
  </div>
</div>
